# ============================================================
# 🔧 VARIÁVEIS DE AMBIENTE
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# Comando: cp .example.env .env
#
# ⚠️ NUNCA commite o arquivo .env no git!
# O .gitignore já protege isso, mas é bom lembrar.
# ============================================================

# ── URL da Aplicação ───────────────────────────────────────
# URL base onde a aplicação roda.
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com
NEXT_PUBLIC_URL = "http://localhost:3000"

# ── Banco de Dados (PostgreSQL) ───────────────────────────
# URL de conexão com o PostgreSQL.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Exemplo: postgresql://postgres:senha123@localhost:5432/raauth
DATABASE_URL = "postgresql://usuario:senha@localhost:5432/raauth"

# ── Better Auth ────────────────────────────────────────────
# URL base da API de autenticação (geralmente igual à URL da app)
BETTER_AUTH_URL = "http://localhost:3000"

# Configuração de Passkeys (WebAuthn)
# RP ID deve ser o domínio base da aplicação. Em dev pode ser localhost.
# Em produção, se sua app roda em subdomínios, normalmente use o domínio raiz.
# Exemplo: para app.raave.dev e dash.raave.dev, use rpID = "raave.dev"
BETTER_AUTH_PASSKEY_RP_ID = "localhost"

# Nome exibido para o usuário durante o registro da passkey
BETTER_AUTH_PASSKEY_RP_NAME = "Raauth"

# Lista opcional de origins válidas para passkeys (separadas por vírgula, sem trailing slash)
# Use quando houver múltiplos domínios/subdomínios ou ambientes.
# Exemplo: "http://localhost:3000,https://app.raave.dev,https://dash.raave.dev"
BETTER_AUTH_PASSKEY_ORIGINS = ""

# Chave secreta para criptografia de sessões e tokens.
# DEVE ter pelo menos 32 caracteres. Gere uma assim:
# openssl rand -base64 32
BETTER_AUTH_SECRET = ""

# ── OAuth: Microsoft ──────────────────────────────────────
# Registre seu app em: https://portal.azure.com → Azure AD
# Callback URL: http://localhost:3000/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID = ""
MICROSOFT_CLIENT_SECRET = ""

# ── OAuth: Google ──────────────────────────────────────────
# Registre seu app em: https://console.cloud.google.com
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""

# ── OAuth: GitHub ──────────────────────────────────────────
# Registre seu app em: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID = ""
GITHUB_CLIENT_SECRET = ""

# ── E-mail (Resend) ───────────────────────────────────────
# Crie sua conta em: https://resend.com
# API key disponível em: https://resend.com/api-keys
RESEND_API_KEY = ""

# ── Automação (n8n) ────────────────────────────────────────
# Webhook que recebe o payload normalizado da solicitação.
# Exemplo: https://n8n.seudominio.com/webhook/form-it/equipment-request
N8N_EQUIPMENT_REQUEST_WEBHOOK_URL = ""
